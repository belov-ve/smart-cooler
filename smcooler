#!/usr/bin/env python3
# coding=utf8

import os
import signal
import sys
import subprocess
from re import findall
from time import sleep
from gpiozero import OutputDevice

# ---------- НАСТРОЙКИ ----------
tempOn = 54          # температура включения (°C)
deltaOff = 4         # гистерезис (выключение при tempOn - deltaOff)
controlPin = 14      # BCM номер пина
activeHigh = True    # True = HIGH включает вентилятор, False = LOW включает
# -----------------------------

pidfile = "/run/smcooler.pid"
cont = True

def log(msg):
    print(f"smcooler: {msg}", flush=True)

def get_temp():
    out = subprocess.check_output(["vcgencmd", "measure_temp"], text=True)
    return float(findall(r'\d+\.\d+', out)[0])

def kill_proc():
    try:
        with open(pidfile) as f:
            pid = f.read().strip()
        if pid:
            os.kill(int(pid), signal.SIGKILL)
            log(f"Killed process {pid}")
    except Exception:
        pass   # не логируем, если файла нет или процесс уже завершён

def set_pid():
    with open(pidfile, "w") as f:
        f.write(str(os.getpid()))
    log("start")

def cooler_control(fan):
    last_state = None   # 'on', 'off' или None
    while True:
        tmp = get_temp()
        if tmp >= tempOn:
            new_state = 'on'
        elif tmp <= tempOn - deltaOff:
            new_state = 'off'
        else:
            new_state = last_state   # состояние не меняется

        if new_state != last_state:
            if new_state == 'on':
                fan.on()
                log(f"fan On (temp={tmp:.1f}°C)")
            elif new_state == 'off':
                fan.off()
                log(f"fan Off (temp={tmp:.1f}°C)")
            last_state = new_state
        sleep(2)

def handler(signum, frame):
    global cont
    cont = False

# ---------- ОСНОВНАЯ ЛОГИКА ----------
if len(sys.argv) == 1:
    # Режим вывода температуры
    signal.signal(signal.SIGINT, handler)
    while cont:
        print(f"Temp={get_temp():.1f}°C")
        sleep(1)

elif sys.argv[1] == "start":
    set_pid()
    fan = OutputDevice(controlPin, active_high=activeHigh, initial_value=False)
    fan.off()
    try:
        cooler_control(fan)
    except Exception as e:
        log(f"Error: {e}")

elif sys.argv[1] == "stop":
    kill_proc()
    sleep(1)
    level = "dh" if activeHigh else "dl"   # dh = HIGH, dl = LOW
    try:
        subprocess.run(["pinctrl", "set", str(controlPin), "op", level],
                       check=True, capture_output=True)
        log("stop (fan On)")
    except Exception as e:
        log(f"stop failed: {e}")
